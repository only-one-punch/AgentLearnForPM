# Public app URL used by auth callbacks and absolute links.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Bind the container to localhost on the host. nginx/caddy should proxy to this in production.
HOST_PORT=3000

# Auth/session secrets. Generate real values on the server; never commit them.
AUTH_SECRET=replace-with-a-random-32-byte-secret
BETTER_AUTH_SECRET=replace-with-a-random-32-byte-secret

# SQLite persistence.
DATA_DIR=./data
DATABASE_PATH=./data/workbench.sqlite
WORKBENCH_DB_PATH=./data/workbench.sqlite

# Generated content.
GENERATED_CONTENT_DIR=.generated/knowledge
KNOWLEDGE_ARTIFACT_DIR=.generated/knowledge
CONTENT_SOURCE_DIR=agent-pm-tech-knowledge
CONTENT_REPO_DIR=.

# Primary user bootstrap. Set these only for initial seed-user execution.
PRIMARY_USER_EMAIL=you@example.com
PRIMARY_USER_PASSWORD=replace-with-a-strong-password
PRIMARY_USER_NAME=Agent PM
WORKBENCH_PRIMARY_EMAIL=you@example.com
WORKBENCH_PRIMARY_PASSWORD=replace-with-a-strong-password
WORKBENCH_PRIMARY_NAME=Agent PM

# Content refresh behavior.
REFRESH_ALLOW_GIT_PULL=false
REFRESH_GIT_REMOTE=origin
REFRESH_GIT_BRANCH=main
REFRESH_STATUS_PATH=./data/refresh-status.json
REFRESH_WEBHOOK_SECRET=replace-only-if-webhook-is-enabled

# Backups.
BACKUP_DIR=./backups
